{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/payments",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/quotation-followups",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/compliance-recurring",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
